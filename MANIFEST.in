include README.md
include LICENSE
include requirements.txt
include .env.example
include QUICKSTART.md
include DISTRIBUTE.md
recursive-include src *.py *.md *.txt
recursive-include cmd *.py
recursive-include config *.py
recursive-include skills *.md
recursive-include scripts *.sh *.md
recursive-include doc *.md
global-include *.example

# 排除不必要的目录
prune .claude
prune build
prune dist
prune *.egg-info
prune __pycache__
prune .venv
prune venv
prune .pytest_cache
prune .mypy_cache
prune logs
prune cache
prune data
prune tests
