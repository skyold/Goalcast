# Environment variables template
# Copy this file to .env and fill in your API keys

# LLM (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: LLM_PROVIDER=anthropic  LLM_MODEL=claude-sonnet-4-20250514

# Data Sources
SPORTMONKS_API_KEY=your_sportmonks_api_key_here
# FOOTYSTATS_API_KEY=your_footystats_api_key_here   (optional fallback)
# FOOTBALL_DATA_API_KEY=your_football_data_key_here  (optional)
# ODDS_API_KEY=your_odds_api_key_here                (optional)
# OPENWEATHER_API_KEY=your_openweather_key_here      (optional)

# DeepSeek (alternative LLM provider)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional overrides
# GOALCAST_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=https://api.anthropic.com  (for proxies/gateways)
# DATABASE_URL=sqlite:///data/db/goalcast.db
